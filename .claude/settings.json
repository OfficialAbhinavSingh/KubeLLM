{
  "model": "claude-sonnet-4-5",
  "context_files": [
    "CLAUDE.md",
    "docs/architecture.md"
  ],
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(python:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(mypy:*)",
      "Bash(kubeconform:*)",
      "Bash(helm template:*)",
      "Bash(helm lint:*)",
      "Bash(kustomize build:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl --dry-run=*)",
      "Bash(kubellm generate:*)",
      "Bash(kubellm scan:*)",
      "Bash(kubellm fix:*)",
      "Bash(kubellm validate:*)",
      "Bash(kubellm verify:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(pip install:*)",
      "Bash(pip-compile:*)",
      "Read(*)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(docs/**)",
      "Write(charts/**)",
      "Write(manifests/**)",
      "Write(infra/**)",
      "Write(frontend/**)",
      "Write(pyproject.toml)",
      "Write(Makefile)",
      "Write(.env.example)"
    ],
    "deny": [
      "Bash(kubectl apply:*)",
      "Bash(kubectl edit:*)",
      "Bash(kubectl patch:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl port-forward:*)",
      "Bash(kubectl replace:*)",
      "Bash(kubectl rollout restart:*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(*secret*)",
      "Write(*credentials*)",
      "Write(*token*)",
      "Write(src/safety/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-write.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash.sh"
          }
        ]
      }
    ]
  },
  "proactive_mode": {
    "enabled": true,
    "default_confidence_for_generated_configs": "medium",
    "require_approval_for_all_proactive_prs": true,
    "gpu_math_precision": "conservative"
  }
}
